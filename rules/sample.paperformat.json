{
  "profileName": "Color Coverage Test",
  "version": "1.2.0",
  "description": "Color test profile for the currently supported document elements.",
  "document": {
    "enforceA4Paper": false
  },
  "captionNumbering": {
    "enabled": true,
    "autoFixPlainText": true,
    "severity": "Warning",
    "figurePatterns": [
      "^(?:Figure|\\u56FE)\\s*(?:(\\d+)-(\\d+)|(\\d+)).*$"
    ],
    "tablePatterns": [
      "^(?:Table|\\u8868)\\s*(?:(\\d+)-(\\d+)|(\\d+)).*$"
    ]
  },
  "paragraphRules": [
    {
      "ruleId": "heading-1-color",
      "displayName": "Heading 1 color",
      "storyScopes": [ "Main" ],
      "styleNames": [ "Heading 1", "\\u6807\\u9898 1" ],
      "outlineLevels": [ 1 ],
      "textPatterns": [ "^(?:\\u7b2c[\\u4e00-\\u4e8c\\u4e09\\u56db\\u4e94\\u516d\\u4e03\\u516b\\u4e5d\\u5341\\u767e]+\\u7ae0)\\s*.*$" ],
      "severity": "Error",
      "expected": {
        "fontColor": "#D32F2F"
      }
    },
    {
      "ruleId": "heading-2-color",
      "displayName": "Heading 2 color",
      "storyScopes": [ "Main" ],
      "styleNames": [ "Heading 2", "\\u6807\\u9898 2" ],
      "outlineLevels": [ 2 ],
      "textPatterns": [ "^\\d+\\.\\d+\\s+.+$" ],
      "severity": "Error",
      "expected": {
        "fontColor": "#1976D2"
      }
    },
    {
      "ruleId": "heading-3-color",
      "displayName": "Heading 3 color",
      "storyScopes": [ "Main" ],
      "styleNames": [ "Heading 3", "\\u6807\\u9898 3" ],
      "outlineLevels": [ 3 ],
      "textPatterns": [ "^\\d+\\.\\d+\\.\\d+\\s+.+$" ],
      "severity": "Error",
      "expected": {
        "fontColor": "#388E3C"
      }
    },
    {
      "ruleId": "toc-1-color",
      "displayName": "TOC 1 color",
      "storyScopes": [ "Main" ],
      "styleNames": [ "TOC 1", "\\u76ee\\u5f55 1" ],
      "severity": "Warning",
      "expected": {
        "fontColor": "#8E24AA"
      }
    },
    {
      "ruleId": "toc-2-color",
      "displayName": "TOC 2 color",
      "storyScopes": [ "Main" ],
      "styleNames": [ "TOC 2", "\\u76ee\\u5f55 2" ],
      "severity": "Warning",
      "expected": {
        "fontColor": "#00897B"
      }
    },
    {
      "ruleId": "toc-3-color",
      "displayName": "TOC 3 color",
      "storyScopes": [ "Main" ],
      "styleNames": [ "TOC 3", "\\u76ee\\u5f55 3" ],
      "severity": "Warning",
      "expected": {
        "fontColor": "#FB8C00"
      }
    },
    {
      "ruleId": "figure-caption-color",
      "displayName": "Figure caption color",
      "storyScopes": [ "Main" ],
      "styleNames": [ "Caption", "\\u9898\\u6ce8" ],
      "textPatterns": [ "^(?:\\u56FE)\\s*(?:\\d+-)?\\d+.*$" ],
      "severity": "Warning",
      "expected": {
        "fontColor": "#6D4C41"
      }
    },
    {
      "ruleId": "table-caption-color",
      "displayName": "Table caption color",
      "storyScopes": [ "Main" ],
      "styleNames": [ "Caption", "\\u9898\\u6ce8" ],
      "textPatterns": [ "^(?:\\u8868)\\s*(?:\\d+-)?\\d+.*$" ],
      "severity": "Warning",
      "expected": {
        "fontColor": "#8D6E63"
      }
    },
    {
      "ruleId": "table-header-text-color",
      "displayName": "Table header text color",
      "storyScopes": [ "Main" ],
      "applyToTableHeaderParagraph": true,
      "severity": "Warning",
      "expected": {
        "fontColor": "#00796B"
      }
    },
    {
      "ruleId": "table-body-text-color",
      "displayName": "Table body text color",
      "storyScopes": [ "Main" ],
      "applyToTableBodyParagraph": true,
      "severity": "Warning",
      "expected": {
        "fontColor": "#546E7A"
      }
    },
    {
      "ruleId": "header-color",
      "displayName": "Header color",
      "storyScopes": [ "Header" ],
      "applyToAnyNonEmptyParagraph": true,
      "severity": "Warning",
      "expected": {
        "fontColor": "#C2185B"
      }
    },
    {
      "ruleId": "page-number-color",
      "displayName": "Page number color",
      "storyScopes": [ "Header", "Footer" ],
      "applyToPageNumberParagraph": true,
      "severity": "Warning",
      "expected": {
        "fontColor": "#455A64"
      }
    },
    {
      "ruleId": "footer-color",
      "displayName": "Footer color",
      "storyScopes": [ "Footer" ],
      "applyToAnyNonEmptyParagraph": true,
      "severity": "Warning",
      "expected": {
        "fontColor": "#3949AB"
      }
    },
    {
      "ruleId": "body-color",
      "displayName": "Body color",
      "storyScopes": [ "Main" ],
      "applyToAnyNonEmptyParagraph": true,
      "severity": "Warning",
      "expected": {
        "fontColor": "#37474F"
      }
    },
    {
      "ruleId": "bibliography-color",
      "displayName": "Bibliography color",
      "storyScopes": [ "Main" ],
      "applyToBibliographyParagraph": true,
      "textPatterns": [
        "^(\\[\\d+\\]|\\(\\d+\\)|\\d+\\.\\s|[A-Z][A-Za-z'\\- ]+,|[\\u4E00-\\u9FFF]{1,6}[，,、].*\\d{4})"
      ],
      "severity": "Warning",
      "expected": {
        "fontColor": "#5D4037"
      }
    }
  ]
}
